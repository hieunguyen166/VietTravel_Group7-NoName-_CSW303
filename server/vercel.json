    {
    "version": 2,
    "builds": [
        {
        "src": "server.js",
        "use": "@vercel/node",
        "config": {
            "includeFiles": ["configs/**", "routes/**", "models/**", "controllers/**"]
        }
        }
    ],
    "routes": [
        {
        "src": "/(.*)",
        "dest": "server.js"
        }
    ]
    }